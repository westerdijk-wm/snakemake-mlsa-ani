        """


rule genes_qc:
    input:
        fasta="results/genes/map-pool/map-pool.fas",
        ref="resources/db/ref-genes.validated.fas",
        validated_ref="results/QC/ref_genes.validated",
        public_genome_files=expand("resources/public_genomes/{sample}.fna", sample=PUBLIC_GENOMES),
        local_genome_files=expand("{genome}", genome=LOCAL_GENOMES),
    output:
        detail="results/QC/gene-qc-detail.tsv",
        matrix="results/QC/gene-qc-matrix.tsv",
        filtered="results/genes/map-pool/map-pool.filtered.fas",
        sample_lists="results/QC/genome-list-pass.txt",
    log:
        log="logs/genes-qc.log",
    conda:
        "envs/genes-qc.yaml"
    threads: min(4, workflow.cores)

    script:
        "scripts/genes-qc.py"


rule table_plot:
    input:
        tsv="results/QC/gene-qc-matrix.tsv",
    output:
        pdf=report(
            "results/QC/gene-qc-matrix.pdf", caption="report/gene_presence.rst", category="QC"
        ),
    conda:
        "envs/R.yaml"
    script:
        "scripts/table-plot.R"


rule align:
    input:
        "results/genes/map-pool/map-pool.filtered.fas",
    output:
        "results/genes/aligned/{gene}.fas",
    log:
        "logs/muscle/{gene}.log",
    threads: min(4, workflow.cores)
    conda:
        "envs/align.yaml"
    shell:
        """
        cat {input} | fasta_grep {wildcards.gene} | muscle >{output} 2>{log}
        """


rule concat:
    input:
        expand("results/genes/aligned/{gene}.fas", gene=config["genes"]),
    output:
        fas="results/genes/concat/concat.fas",
        tab="results/genes/concat/concat.tab",
    threads: min(4, workflow.cores)
    conda:
        "envs/fasta_tools.yaml"
    shell:
        """
        fasta_autoconcatenate -r='{autoconcatenate_regex}' {input} >{output.fas} 2>{output.tab}
        """


rule partition_file:
    input:
        "results/genes/concat/concat.tab",
    output:
        "results/genes/concat/concat.part",
    shell:
        """
        perl -ne '{parition_regex}' {input} >{output}
        """

rule reroot_tree:
    input:
        TREE_OUTPUT,
    output:
        "results/phylogenetics/MLSA.nwk",
    log:
        "logs/reroot_tree.log",
    conda:
        "envs/newick_utils.yaml"
    shell:
        """
        nw_reroot -s {input} >{output} 2>{log}
        """

