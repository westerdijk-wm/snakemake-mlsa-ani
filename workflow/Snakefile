configfile: "config.yaml"

include: "rules/common.smk"

for rulefile in ANI_RULES:
    include: rulefile

include: TREE_RULES

rule all:
    input:
        "quast/report.pdf",
        "phylogenetics/MLSA.nwk",
        ANI_TARGETS,
        TREE_TARGETS,
        PUBLIC_GENOME_TARGETS

rule download_public_genome:
    """
    Download a public genome from NCBI.
    """
    output:
        "public_genomes/{accession}.fna"
    shell:
        """
        mkdir -p public_genomes

        datasets download genome accession \
            {wildcards.accession} \
            --include genome \
            --filename {wildcards.accession}.zip

        unzip -oq {wildcards.accession}.zip -d {wildcards.accession}

        cp $(find {wildcards.accession} -name "*.fna" | head -n 1) {output}

        rm -rf {wildcards.accession}
        rm -f {wildcards.accession}.zip
        """

