for rulefile in ANI_RULES:
    include: rulefile

include: TREE_RULES

rule all:
    input:
        "quast/report.pdf",
        "results/MLSA.nwk",
        ANI_TARGETS,
        TREE_TARGETS

# Get data from NCBI
rule dataset:
    """
    Download data from NCBI and place it to correct location
    """
    input:
        "ncbi-ids.txt"
    output:
        "download/ncbi_dataset.zip",
        "download/README.md"
    shell:
        """
        datasets download genome accession --inputfile {input} --include genome,gff3 --filename {output[0]}
        cd download
        unzip ncbi_dataset.zip
        """


rule move_dataset:
    """
    Place the donwloaded dataset to correct location
    """
    input:
        "download/README.md"
    output:
        "download/renamed.log"
    shell:
        """
        workflow/scripts/rename-download.py >{output}
        cp download/renamed/*/*.fna genomes/.
        mv download/renamed/* annotation/.
        rm {input}
        """


