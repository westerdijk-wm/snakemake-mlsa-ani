report: "report/workflow.rst"


configfile: "config.yaml"


include: "rules/common.smk"


for rulefile in ANI_RULES:

    include: rulefile


include: TREE_RULES


rule all:
    input:
        expand("QC/quast/{sample}.pdf", sample=SAMPLES),
        "QC/gene-qc-matrix.pdf",
        "phylogenetics/MLSA.nwk",
        ANI_TARGETS,
        TREE_TARGETS,
        PUBLIC_GENOME_TARGETS,


rule download_public_genome:
    """
    Download a public genome from NCBI.
    """
    output:
        "public_genomes/{accession}.fna",
    log:
        "logs/download/{accession}.log",
    shell:
        """
        mkdir -p public_genomes

        datasets download genome accession {wildcards.accession} \
            --include genome \
            --filename {wildcards.accession}.zip \
            >{log} 2>&1

        unzip -oq {wildcards.accession}.zip -d {wildcards.accession} >>{log} 2>&1

        cp $(find {wildcards.accession} -name "*.fna" | head -n 1) {output}

        rm -rf {wildcards.accession}
        rm -f {wildcards.accession}.zip
        """


# Assembly quality check
rule validate_ref_genes:
    """
    Check reference gene headers.
    """
    input:
        "db/ref-genes.fas",
    output:
        report=touch("QC/ref_genes.validated"),
        fasta="db/ref-genes.validated.fas",
    log:
        "logs/ref_genes_validation.log",
    script:
        "scripts/validate-ref-genes.py"


rule quast:
    """
    Run QUAST on assemblies for QC.
    """
    input:
        fasta=genome_file
    output:
        report_pdf=report(
            "QC/quast/{sample}.pdf",
            caption="report/qc.rst",
            category="QC",
        )
    log:
        "logs/QUAST/{sample}.log"

    threads: workflow.cores
    params:
        extra="--fungus --min-contig 5 --min-identity 95.0"
    wrapper:
        "v9.9.0/bio/quast"


rule minimap2:
    input:
        target=genome_file,
        query="db/ref-genes.validated.fas",
        validated_ref="QC/ref_genes.validated",
    output:
        temp("minimap/{sample}_mapping.sam"),
    log:
        "logs/minimap/{sample}_minimap2.log",
    threads: workflow.cores
    params:
        extra="-x map-ont",
        sorting="none",
    wrapper:
        "v9.9.0/bio/minimap2/aligner"

rule sam_filter:
    input:
        IN_SAM=temp("minimap/{sample}_mapping.sam"),
    output:
        F_SAM=temp("minimap/{sample}_mapping_filtered.sam"),
    log:
        "logs/minimap/{sample}_samtools.log",
    threads: workflow.cores
    shell:
        """
        samtools view {input.IN_SAM} -F4 -h \
            | sam-flip.pl \
            | sam-keep-best.pl -rid -l -n=1 -po=0.1 \
                >{output.F_SAM} 2>>{log}
        """

rule sam_realign:
    input:
        IN_HITS="minimap/{sample}_mapping_filtered.sam",
        IN_DATABASE="db/ref-genes.validated.fas",
        IN_QUERY=genome_file,
        # validated_ref="QC/ref_genes.validated"
    output:
        OUT_SAM=temp("sam_realign/{sample}_realigned_mapping.sam"),
    log:
        "logs/sam_realign/{sample}.log",
    conda:
        "envs/realign.yaml"
    threads: min(4, workflow.cores)
    script:
        "scripts/sam-realign.sh"


rule sam_extract_hit_seq:
    input:
        IN="sam_realign/{sample}_realigned_mapping.sam",
    output:
        OUT=temp("genes/map/{sample}.fas"),
    threads: min(4, workflow.cores)
    params:
        sim=0.7,
    shell:
        """
        cat {input.IN} \
            | sam-filter.pl -minsim={params.sim} \
            | sam-extract-hit-seq.pl \
            | workflow/scripts/rename-extracted-hit-fasta.pl - -sample={wildcards.sample} >{output.OUT}
        """


rule map_all:
    input:
        expand("genes/map/{sample}.fas", sample=SAMPLES),
    output:
        "genes/map-pool/map-pool.fas",
    threads: min(4, workflow.cores)
    shell:
        """
        cat {input} >{output}
        """


rule gene_qc:
    input:
        fasta="genes/map-pool/map-pool.fas",
        ref="db/ref-genes.validated.fas",
        validated_ref="QC/ref_genes.validated",
    output:
        detail="QC/gene-qc-detail.tsv",
        summary="QC/gene-qc-summary.tsv",
        matrix="QC/gene-qc-matrix.tsv",
        filtered="genes/map-pool/map-pool.filtered.fas",
        sample_lists="QC/genome-list-pass.txt",
    log:
        log="logs/gene-qc.log",
        report="QC/gene-qc.log",
    threads: min(4, workflow.cores)
    script:
        "scripts/genes-qc.py"

rule table_plot:
    input:
        tsv="QC/gene-qc-matrix.tsv",
    output:
        pdf=report(
            "QC/gene-qc-matrix.pdf", caption="report/gene_presence.rst", category="QC"
        ),
    conda:
        "envs/R.yaml"
    script:
        "scripts/table-plot.R"


rule align:
    input:
        "genes/map-pool/map-pool.filtered.fas",
    output:
        "genes/aligned/{gene}.fas",
    log:
        "logs/muscle/{gene}.log",
    threads: min(4, workflow.cores)
    shell:
        """
        cat {input} | fasta_grep {wildcards.gene} | muscle >{output} 2>{log}
        """


rule concat:
    input:
        expand("genes/aligned/{gene}.fas", gene=config["genes"]),
    output:
        fas="genes/concat/concat.fas",
        tab="genes/concat/concat.tab",
    threads: min(4, workflow.cores)
    shell:
        """
        fasta_autoconcatenate -r='{autoconcatenate_regex}' {input} >{output.fas} 2>{output.tab}
        """


rule partition_file:
    input:
        "genes/concat/concat.tab",
    output:
        "genes/concat/concat.part",
    shell:
        """
        perl -ne '{parition_regex}' {input} >{output}
        """

rule reroot_tree:
    input:
        TREE_OUTPUT,
    output:
        "phylogenetics/MLSA.nwk",
    log:
        "logs/reroot_tree.log",
    shell:
        """
        nw_reroot -s {input} >{output} 2>{log}
        """

rule ani_table:
    input:
        lambda wc: ANI_TABLE_INPUT[wc.tsv],
    output:
        "{tsv}",
    wildcard_constraints:
        tsv="|".join(ANI_TABLE_INPUT.keys()).replace("/", "\\/"),
    script:
        "scripts/ani2table.py"

rule ani_plot:
    input:
        tree=lambda wc: ANI_PLOT_INPUT[wc.pdf]["tree"],
        ani=lambda wc: ANI_PLOT_INPUT[wc.pdf]["ani"],
    output:
        pdf=report("{pdf}", caption="report/ani.rst", category="ANI"),
    log:
        "logs/ANI/ani_plot_{pdf}.log",
    wildcard_constraints:
        pdf="|".join(ANI_PLOT_INPUT.keys()).replace("/", "\\/"),
    threads: min(4, workflow.cores)
    params:
        labels=config.get("sample_labels", ""),
    script:
        "scripts/tree-ANI-heatmap.R"
