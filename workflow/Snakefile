rule get_genome:
    """
    Download data from NCBI and place it to correct location
    """
    output:
        fasta="resources/public_genomes/{sample}.fna",
        zip=temp("resources/datasets/{sample}.zip"),
        dir=temp(directory("resources/datasets/{sample}"))
    wildcard_constraints:
        sample=ACCESSION_SAMPLES
    conda:
        "envs/ncbi-datasets.yaml"
    log:
        "logs/datasets/{sample}.log",
    params:
        accession=lambda wildcards: accessions.loc[wildcards.sample, 'assembly']
    shell:
        """
        datasets download genome accession {params.accession} --include genome --filename {output.zip}
        unzip {output.dir}.zip -d {output.dir}
        mv {output.dir}/ncbi_dataset/data/{params.accession}/{params.accession}*_genomic.fna {output.fasta}
        """
        
    # rule download_public_genome:
    # """
    # Download a public genome from NCBI.
    # """
    # output:
    #     "resources/public_genomes/{accession}.fna",
    # log:
    #     "logs/download/{accession}.log",
    # shell:
    #     """
    #     mkdir -p public_genomes

    #     datasets download genome accession {wildcards.accession} \
    #         --include genome \
    #         --filename {wildcards.accession}.zip \
    #         >{log} 2>&1

    #     unzip -oq {wildcards.accession}.zip -d {wildcards.accession} >>{log} 2>&1

    #     cp $(find {wildcards.accession} -name "*.fna" | head -n 1) {output}

    #     rm -rf {wildcards.accession}
    #     rm -f {wildcards.accession}.zip
    #     """


# Assembly quality check
rule validate_ref_genes:
    """
    Check reference gene headers.
    """
    input:
        REF_GENES,
    output:
        report=touch("results/QC/ref_genes.validated"),
        fasta="resources/db/ref-genes.validated.fas",
    log:
        "logs/ref_genes_validation.log",
    conda:
        "envs/biopython.yaml"
    script:
        "scripts/validate-ref-genes.py"


rule quast:
    """
    Run QUAST on assemblies for QC.
    """
    input:
        fasta=genome_file
    output:
        report_pdf=report(
            "results/QC/quast/{sample}.pdf",
            caption="report/qc.rst",
            category="QC",
        )
    log:
        "logs/QUAST/{sample}.log"

    threads: min(8, workflow.cores)
    params:
        extra="--fungus --min-contig 5 --min-identity 95.0"
    wrapper:
        "v9.9.0/bio/quast"


rule minimap2:
    input:
        target=genome_file,
        query="resources/db/ref-genes.validated.fas",
        validated_ref="results/QC/ref_genes.validated",
    output:
        temp("results/minimap2/{sample}_mapping.sam"),
    log:
        "logs/minimap/{sample}_minimap2.log",
    threads: workflow.cores
    params:
        extra="-x map-ont -p 0.5", # may need a more relaxed secondary hits '-p 0.5'
        sorting="none",
    wrapper:
        "v9.9.0/bio/minimap2/aligner"

rule sam_filter:
    input:
        IN_SAM=("results/minimap2/{sample}_mapping.sam"),
    output:
        F_SAM=temp("results/minimap2/{sample}_mapping_filtered.sam"),
    log:
        "logs/minimap/{sample}_samtools.log",
    threads: workflow.cores
    conda:
        "envs/sam-harmonization.yaml"
    shell:
        """
        samtools view {input.IN_SAM} -F4 -h \
            | sam-flip.pl \
            | sam-keep-best.pl -rid -l -n=1 -po=0.1 \
                >{output.F_SAM} 2>>{log}
        """

rule sam_realign:
    input:
        "results/minimap2/{sample}_mapping_filtered.sam",
        "resources/db/ref-genes.validated.fas",
        genome_file,
        # validated_ref="results/QC/ref_genes.validated"
    output:
        temp("results/sam_realign/{sample}_realigned_mapping.sam"),
    log:
        "logs/sam_realign/{sample}.log",
    conda:
        "envs/realign.yaml"
    # threads: min(4, workflow.cores)
    script:
        "scripts/sam-realign.sh"


rule sam_extract_hit_seq:
    input:
        "results/sam_realign/{sample}_realigned_mapping.sam",
    output:
        temp("results/genes/map_raw/{sample}.fas"),
    threads: min(4, workflow.cores)
    params:
        sim=0.7,
    conda:
        "envs/sam-harmonization.yaml"
    shell:
        """
        cat {input} \
            | sam-filter.pl -minsim={params.sim} \
            | sam-extract-hit-seq.pl \
            > {output}
        """

rule rename_extracted_hit_seq:
    input:
        "results/genes/map_raw/{sample}.fas"
    output:
        temp("results/genes/map/{sample}.fas")
    script:
        "scripts/rename-extracted-hit-fasta.sh"


